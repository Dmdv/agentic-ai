### skills/python-guidelines/templates/standard.toml ###
[build-system]
requires = ["setuptools>=68.0", "wheel"]
build-backend = "setuptools.build_meta"


[project]
name = "my-project"
version = "1.0.0"
description = "Project description"
requires-python = ">=3.14"
dependencies = []


[project.optional-dependencies]
dev = [
    "ruff>=0.8.0",
    "mypy>=1.13.0",
    "pytest>=8.0.0",
    "pytest-asyncio>=0.24.0",
    "pytest-cov>=4.1.0",
]

# ==============================================================================
# RUFF - Linter & Formatter (replaces black, isort, flake8, pyupgrade)
# ==============================================================================

[tool.ruff]
line-length = 88
target-version = "py314"
exclude = [
    ".git",
    ".venv",
    "venv",
    "__pycache__",
    "build",
    "dist",
]


[tool.ruff.lint]
# Standard rule set - catches bugs and enforces best practices
select = [
    "E",     # pycodestyle errors
    "F",     # Pyflakes
    "W",     # pycodestyle warnings
    "I",     # isort
    "B",     # flake8-bugbear (common bugs)
    "C4",    # flake8-comprehensions (better comprehensions)
    "UP",    # pyupgrade (modern Python syntax)
    "SIM",   # flake8-simplify (simplify code)
    "N",     # pep8-naming (naming conventions)
    "RUF",   # Ruff-specific rules
]

ignore = [
    "E501",     # Line too long (handled by formatter)
    "SIM108",   # Ternary operator (sometimes less readable)
]


[tool.ruff.lint.per-file-ignores]
"__init__.py" = ["F401"]  # Allow unused imports in __init__
"tests/**/*.py" = ["B", "SIM"]  # Relax for tests


[tool.ruff.lint.isort]
known-first-party = ["src", "app"]
combine-as-imports = true

# ==============================================================================
# MYPY - Static Type Checker
# ==============================================================================

[tool.mypy]
python_version = "3.14"
strict = true
plugins = ["pydantic.mypy"]
warn_return_any = true
warn_unused_configs = true
warn_redundant_casts = true
warn_unused_ignores = true
show_error_codes = true
show_column_numbers = true
ignore_missing_imports = true

# Relax for tests

[tool.pytest.ini_options]
testpaths = ["tests"]
python_files = ["test_*.py", "*_test.py"]
python_classes = ["Test*"]
python_functions = ["test_*"]
asyncio_mode = "auto"
addopts = [
    "-v",
    "--strict-markers",
    "--tb=short",
    "-ra",
]
markers = [
    "unit: Unit tests (no external dependencies)",
    "integration: Integration tests (require database)",
    "slow: Slow running tests",
]
filterwarnings = [
    "ignore::DeprecationWarning",
]

# ==============================================================================
# COVERAGE - Test Coverage
# ==============================================================================

[tool.coverage.run]
source = ["src"]
branch = true
omit = ["*/tests/*", "*/__pycache__/*"]


[tool.coverage.report]
exclude_lines = [
    "pragma: no cover",
    "def __repr__",
    "raise NotImplementedError",
    "if __name__ == .__main__.:",
    "if TYPE_CHECKING:",
]
show_missing = true


### skills/python-guidelines/templates/minimal.toml ###
[project]
name = "my-project"
version = "0.1.0"
description = "Project description"
requires-python = ">=3.14"


[project.optional-dependencies]
dev = [
    "ruff>=0.8.0",
    "mypy>=1.13.0",
    "pytest>=8.0.0",
]

# ==============================================================================
# RUFF - Linter & Formatter (replaces black, isort, flake8)
# ==============================================================================

[tool.ruff]
line-length = 88
target-version = "py314"


[tool.ruff.lint]
# Minimal rule set - catches obvious errors
select = [
    "E",   # pycodestyle errors (syntax, indentation)
    "F",   # Pyflakes (undefined names, unused imports)
    "I",   # isort (import sorting)
]


[tool.ruff.lint.isort]
known-first-party = ["src"]

# ==============================================================================
# MYPY - Static Type Checker
# ==============================================================================

[tool.mypy]
python_version = "3.14"
strict = true
ignore_missing_imports = true
show_error_codes = true

# Relax for tests

[tool.pytest.ini_options]
testpaths = ["tests"]
python_files = ["test_*.py"]
python_functions = ["test_*"]
addopts = ["-v", "--strict-markers"]


### skills/python-guidelines/templates/enterprise.toml ###
[build-system]
requires = ["setuptools>=68.0", "wheel"]
build-backend = "setuptools.build_meta"


[project]
name = "enterprise-service"
version = "1.0.0"
description = "Enterprise-grade Python service"
requires-python = ">=3.14"
dependencies = []


[project.optional-dependencies]
dev = [
    "ruff>=0.8.0",
    "mypy>=1.13.0",
    "pytest>=8.0.0",
    "pytest-asyncio>=0.24.0",
    "pytest-cov>=4.1.0",
    "pytest-mock>=3.12.0",
    "bandit>=1.7.0",
    "pip-audit>=2.6.0",
]

# ==============================================================================
# RUFF - Linter & Formatter (ENTERPRISE MODE - ALL RULES)
# ==============================================================================

[tool.ruff]
target-version = "py314"
line-length = 88
exclude = [
    ".git",
    ".hg",
    ".mypy_cache",
    ".ruff_cache",
    ".tox",
    ".venv",
    "venv",
    "__pypackages__",
    "_build",
    "buck-out",
    "build",
    "dist",
    "alembic/versions",
    ".archive",
    "examples/",
    "scripts/",
]


[tool.ruff.lint]
# ENTERPRISE: Maximum rule coverage
select = [
    # Core (Always On)
    "E",     # pycodestyle errors
    "F",     # Pyflakes
    "W",     # pycodestyle warnings
    "I",     # isort

    # Bug Detection
    "B",     # flake8-bugbear - catches common bugs
    "C4",    # flake8-comprehensions - better comprehensions
    "PIE",   # flake8-pie - misc lints
    "RSE",   # flake8-raise - raise statement lints
    "RET",   # flake8-return - return consistency

    # Modernization
    "UP",    # pyupgrade - use modern Python syntax
    "SIM",   # flake8-simplify - simplify code
    "FLY",   # flynt - use f-strings
    "FURB",  # refurb - modernize code

    # Quality
    "N",     # pep8-naming - naming conventions
    "RUF",   # Ruff-specific rules
    "PL",    # Pylint subset (PLW, PLC, PLE, PLR)

    # Performance
    "PERF",  # Performance anti-patterns

    # Best Practices
    "PTH",   # Use pathlib instead of os.path
    "T20",   # flake8-print - no print statements
    "TRY",   # tryceratops - exception handling
    "LOG",   # flake8-logging - logging best practices
    "G",     # flake8-logging-format

    # Security (Enterprise)
    "S",     # flake8-bandit - security vulnerabilities

    # Type Annotations (Enterprise)
    "ANN",   # flake8-annotations - type annotation coverage
    "TCH",   # flake8-type-checking - TYPE_CHECKING blocks
]

ignore = [
    # Complexity (acceptable in some patterns)
    "PLR0913",  # Too many arguments (FastAPI endpoints)
    "PLR2004",  # Magic value comparison (tests/configs)
    "PLR0911",  # Too many return statements
    "PLR0912",  # Too many branches
    "PLR0915",  # Too many statements

    # Exception handling (project patterns)
    "TRY003",   # Long exception messages (user-facing)
    "TRY300",   # Consider else block (style)
    "TRY301",   # Abstract raise
    "TRY401",   # Redundant exception binding
    "TRY002",   # Create custom exception

    # Style preferences
    "RET504",   # Unnecessary assignment before return
    "SIM108",   # Ternary operator
    "SIM102",   # Nested if
    "SIM103",   # Return boolean directly

    # Logging (readable patterns)
    "G004",     # Logging f-string
    "G201",     # Use .exception()

    # FastAPI patterns
    "B008",     # Function call in default (Depends())
    "B904",     # raise from err

    # Annotations (self/cls)
    "ANN101",   # Missing type annotation for self
    "ANN102",   # Missing type annotation for cls
    "ANN401",   # Dynamically typed expressions (Any)

    # Other
    "RUF001",   # Ambiguous unicode
    "RUF003",   # Ambiguous unicode
    "RUF012",   # Mutable class attributes (Pydantic)
    "PERF401",  # List comprehension
    "PLW0602",  # Global variable
    "PLW0603",  # Global statement
]


[tool.ruff.lint.pycodestyle]
max-line-length = 200  # Allow long error messages


[tool.ruff.lint.per-file-ignores]
# FastAPI/Middleware - import ordering for initialization
"app/main.py" = ["E402"]
"app/middleware/*.py" = ["E402"]

# API endpoints
"app/api/**/*.py" = ["E712", "B008"]  # SQLAlchemy ==False, Depends()

# Services with complex patterns
"app/services/*.py" = ["E712", "PLW2901", "B008"]

# Models and schemas
"app/models/**/*.py" = ["E402", "N811", "RUF002"]
"app/schemas/*.py" = ["N805"]

# Core modules
"app/core/*.py" = ["B008", "PLW2901"]

# Security modules
"app/security/*.py" = ["E712", "PLW2901"]

# Alembic migrations
"alembic/**/*.py" = ["E501", "UP", "N999", "PLW", "ANN"]

# Unit tests - relaxed
"tests/unit/*.py" = [
    "F841", "N802", "N803", "N806",  # Naming
    "T20",                           # Print
    "SIM", "RUF002",                 # Simplify
    "PLR0133", "B017",               # Complexity
    "PTH123", "FURB157",             # Paths
    "B007", "TRY400", "PERF102",     # Various
    "S101",                          # Assert
    "ANN",                           # Annotations
]
"tests/unit/**/*.py" = [
    "F841", "N802", "N803", "N806",
    "T20", "SIM", "RUF002",
    "PLR0133", "B017", "PTH123", "FURB157",
    "B007", "TRY400", "PERF102",
    "S101", "ANN",
]

# Integration tests
"tests/integration/*.py" = ["E402", "N802", "N803", "N806", "T20", "SIM", "B", "TRY", "S101", "ANN"]
"tests/integration/**/*.py" = ["E402", "N802", "N803", "N806", "T20", "SIM", "B", "TRY", "S101", "ANN"]

# E2E tests
"tests/e2e/*.py" = ["N802", "N803", "N806", "B", "PLW", "SIM105", "SIM117", "S101", "ANN"]
"tests/e2e/**/*.py" = ["N802", "N803", "N806", "B", "PLW", "SIM105", "SIM117", "S101", "ANN"]

# Conftest files
"tests/**/conftest*.py" = ["E402", "N802", "N803", "N806", "SIM105", "SIM117", "F401", "F811", "F841", "TRY", "RUF022", "ANN"]

# ML/Data Science patterns (if applicable)
"app/ml/**/*.py" = ["N803", "N812", "B006", "B007", "PLW2901", "RUF002", "ANN"]


[tool.ruff.lint.isort]
known-first-party = ["app", "src"]
force-single-line = false
combine-as-imports = true


[tool.ruff.lint.flake8-annotations]
allow-star-arg-any = true
suppress-dummy-args = true

# ==============================================================================
# MYPY - Static Type Checker (ENTERPRISE MODE)
# ==============================================================================

[tool.mypy]
python_version = "3.14"
plugins = ["pydantic.mypy"]

# Strict mode settings
strict = true
warn_return_any = true
warn_unused_configs = true
warn_redundant_casts = true
warn_unused_ignores = true
show_error_codes = true
show_column_numbers = true

# Third-party flexibility
ignore_missing_imports = true
follow_imports = "silent"

exclude = [
    "venv",
    "\\.venv",
    "alembic/versions",
    "tests/e2e_blackbox",
    ".archive",
]

# Per-module overrides for third-party libraries

[tool.pydantic-mypy]
init_forbid_extra = true
init_typed = true
warn_required_dynamic_aliases = true

# ==============================================================================
# PYTEST - Testing Framework (ENTERPRISE)
# ==============================================================================

[tool.pytest.ini_options]
testpaths = ["tests"]
python_files = ["test_*.py", "*_test.py"]
python_classes = ["Test*"]
python_functions = ["test_*"]
asyncio_mode = "auto"
addopts = [
    "-v",
    "--strict-markers",
    "--tb=short",
    "-ra",
]
markers = [
    "unit: Unit tests (no external dependencies)",
    "integration: Integration tests (require database)",
    "e2e: End-to-end tests (require full environment)",
    "slow: Slow running tests",
    "asyncio: Async tests",
    "security: Security-related tests",
    "performance: Performance tests",
]
filterwarnings = [
    "ignore::DeprecationWarning",
    "ignore::PendingDeprecationWarning",
]

# ==============================================================================
# COVERAGE - Test Coverage (ENTERPRISE)
# ==============================================================================

[tool.coverage.run]
source = ["app"]
branch = true
omit = [
    "*/tests/*",
    "*/__pycache__/*",
    "*/venv/*",
    "*/.venv/*",
    "*/alembic/*",
]


[tool.coverage.report]
exclude_lines = [
    "pragma: no cover",
    "def __repr__",
    "raise AssertionError",
    "raise NotImplementedError",
    "if __name__ == .__main__.:",
    "if TYPE_CHECKING:",
    "if typing.TYPE_CHECKING:",
    "class .*\\bProtocol\\):",
    "@(abc\\.)?abstractmethod",
]
fail_under = 80
show_missing = true


[tool.coverage.html]
directory = "htmlcov"

# ==============================================================================
# BANDIT - Security Linter (ENTERPRISE)
# ==============================================================================

[tool.bandit]
exclude_dirs = ["tests", "venv", ".venv", "alembic"]
skips = ["B101"]  # Skip assert warnings (used in tests)


### skills/python-guidelines/templates/strict.toml ###
[build-system]
requires = ["setuptools>=68.0", "wheel"]
build-backend = "setuptools.build_meta"


[project]
name = "my-service"
version = "1.0.0"
description = "Production service"
requires-python = ">=3.14"
dependencies = []


[project.optional-dependencies]
dev = [
    "ruff>=0.8.0",
    "mypy>=1.13.0",
    "pytest>=8.0.0",
    "pytest-asyncio>=0.24.0",
    "pytest-cov>=4.1.0",
    "pytest-mock>=3.12.0",
]

# ==============================================================================
# RUFF - Linter & Formatter (STRICT MODE)
# ==============================================================================

[tool.ruff]
target-version = "py314"
line-length = 88
exclude = [
    ".git",
    ".venv",
    "venv",
    "__pycache__",
    "build",
    "dist",
    "alembic/versions",
    ".archive",
]


[tool.ruff.lint]
# Strict rule set - comprehensive code quality
select = [
    "E",     # pycodestyle errors
    "F",     # Pyflakes
    "W",     # pycodestyle warnings
    "I",     # isort
    "B",     # flake8-bugbear (common bugs)
    "C4",    # flake8-comprehensions
    "UP",    # pyupgrade (modern syntax)
    "SIM",   # flake8-simplify
    "N",     # pep8-naming
    "RUF",   # Ruff-specific rules
    "PERF",  # Performance anti-patterns
    "PL",    # Pylint subset (PLW, PLC, PLE, PLR)
    "PTH",   # Use pathlib instead of os.path
    "T20",   # flake8-print (no print statements)
    "TRY",   # tryceratops (exception handling)
    "PIE",   # flake8-pie (misc lints)
    "RSE",   # flake8-raise
    "RET",   # flake8-return
    "FLY",   # flynt (use f-strings)
    "FURB",  # refurb (modernize code)
    "LOG",   # flake8-logging
    "G",     # flake8-logging-format
]

ignore = [
    "PLR0913",  # Too many arguments (FastAPI endpoints)
    "PLR2004",  # Magic value comparison (tests/configs)
    "PLR0911",  # Too many return statements
    "PLR0912",  # Too many branches
    "TRY003",   # Long exception messages (user-facing)
    "TRY300",   # Consider else block (style)
    "RET504",   # Unnecessary assignment before return
    "SIM108",   # Ternary operator
    "G004",     # Logging f-string (readable)
    "B008",     # Function call in default (FastAPI Depends)
]


[tool.ruff.lint.per-file-ignores]
# FastAPI patterns
"app/api/**/*.py" = ["B008"]  # Depends() in defaults
"app/main.py" = ["E402"]      # Import order for middleware

# Tests - relaxed rules
"tests/**/*.py" = [
    "N802", "N803", "N806",  # Naming conventions
    "B", "SIM",              # Bugbear, simplify
    "T20",                   # Print statements OK
    "PLR",                   # Pylint complexity
    "FURB157",               # Decimal("string") needed
]

# Alembic migrations
"alembic/**/*.py" = ["E501", "UP", "N999", "PLW"]


[tool.ruff.lint.isort]
known-first-party = ["app", "src"]
combine-as-imports = true

# ==============================================================================
# MYPY - Static Type Checker (STRICT MODE)
# ==============================================================================

[tool.mypy]
python_version = "3.14"
plugins = ["pydantic.mypy"]
strict = true
warn_return_any = true
warn_unused_configs = true
warn_redundant_casts = true
warn_unused_ignores = true
show_error_codes = true
show_column_numbers = true
ignore_missing_imports = true

exclude = [
    "venv",
    "\\.venv",
    "alembic/versions",
]

# Third-party without stubs

[tool.pytest.ini_options]
testpaths = ["tests"]
python_files = ["test_*.py", "*_test.py"]
python_classes = ["Test*"]
python_functions = ["test_*"]
asyncio_mode = "auto"
addopts = [
    "-v",
    "--strict-markers",
    "--tb=short",
    "-ra",
]
markers = [
    "unit: Unit tests (no external dependencies)",
    "integration: Integration tests (require database)",
    "e2e: End-to-end tests (require full environment)",
    "slow: Slow running tests",
    "asyncio: Async tests",
]
filterwarnings = [
    "ignore::DeprecationWarning",
    "ignore::PendingDeprecationWarning",
]

# ==============================================================================
# COVERAGE - Test Coverage
# ==============================================================================

[tool.coverage.run]
source = ["app", "src"]
branch = true
omit = [
    "*/tests/*",
    "*/__pycache__/*",
    "*/venv/*",
    "*/.venv/*",
    "*/alembic/*",
]


[tool.coverage.report]
exclude_lines = [
    "pragma: no cover",
    "def __repr__",
    "raise AssertionError",
    "raise NotImplementedError",
    "if __name__ == .__main__.:",
    "if TYPE_CHECKING:",
    "if typing.TYPE_CHECKING:",
    "class .*\\bProtocol\\):",
    "@(abc\\.)?abstractmethod",
]
fail_under = 70
show_missing = true


[tool.coverage.html]
directory = "htmlcov"


